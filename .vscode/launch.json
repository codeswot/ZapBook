    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "zapbook",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "zapbook (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "zapbook (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "zapbook android dev mode",
            "request": "launch",
            "type": "dart",
            "env": {
                "APP_ID_SUFFIX": ".dev"
            }
        },
    ]
}